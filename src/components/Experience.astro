---
---
<section class="experience" id="experience">
  <div class="container">
    <div class="exp-header">
      <p class="section-label">Experience</p>
      <h2 class="section-title">Where I've worked</h2>
    </div>

    <div class="timeline">
      <!-- Current role -->
      <div class="timeline-item current">
        <div class="timeline-dot active"></div>
        <div class="timeline-content">
          <div class="exp-card">
            <div class="exp-top">
              <div class="exp-company-logo">I</div>
              <div class="exp-info">
                <h3 class="exp-title">Application Developer-Cloud FullStack</h3>
                <p class="exp-company">IBM</p>
              </div>
              <span class="exp-badge current-badge">Current</span>
            </div>
            <p class="exp-date">April 2026 – Present · Quezon City, Philippines</p>
            <ul class="exp-bullets">
              <li>in progress</li>
            </ul>
            <div class="exp-tags">
              <span class="skill-tag">in progress</span>
            </div>
          </div>
        </div>
      </div>
              

      <!-- Previous role -->
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="exp-card">
            <div class="exp-top">
              <div class="exp-company-logo">S</div>
              <div class="exp-info">
                <h3 class="exp-title">Android Software Engineer II</h3>
                <p class="exp-company">Stratpoint Technologies</p>
              </div>
              <span class="exp-badge intern-badge">First Job</span>
            </div>
            <p class="exp-date">June 2025 – Oct 2025 · Mandaluyong City, Philippines</p>
            <ul class="exp-bullets">
              <li>Developed and optimized multiple Android features for the <strong>Cebu Pacific Mobile app</strong>, improving reliability and performance for <strong>1M+ active users</strong></li>
              <li>Implemented error validation logic for voucher redemption, reducing transaction errors by <strong>40%</strong> during high-volume usage</li>
              <li>Migrated business rule engine to a centralized CMS, enabling non-technical teams to update configs and reducing release cycles by <strong>25%</strong></li>
              <li>Contributed to payment system migration by optimizing Android-to-backend data flow, boosting transaction success rate by <strong>20%</strong></li>
              <li>Collaborated with Cebu Pacific and Vietnam-based teams in an <strong>Agile Scrum</strong> environment using Azure DevOps</li>
            </ul>
            <div class="exp-tags">
              <span class="skill-tag">Kotlin</span>
              <span class="skill-tag">Android SDK</span>
              <span class="skill-tag">React Native</span>
              <span class="skill-tag">MVVM</span>
              <span class="skill-tag">Azure DevOps</span>
              <span class="skill-tag">Agile Scrum</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Internship -->
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="exp-card">
            <div class="exp-top">
              <div class="exp-company-logo intern">S</div>
              <div class="exp-info">
                <h3 class="exp-title">Android Software Engineer Intern</h3>
                <p class="exp-company">Stratpoint Technologies</p>
              </div>
              <span class="exp-badge intern-badge">Internship</span>
            </div>
            <p class="exp-date">2025 · Metro Manila, Philippines</p>
            <ul class="exp-bullets">
              <li>Built <strong>Filmhub</strong> — an offline-first movie discovery app using Kotlin, Room DB, and theMovieDB API; presented to senior engineers and HR leadership</li>
              <li>Completed <strong>Android Immersion Training</strong> covering Kotlin, MVVM, Room DB, caching, and offline-first architecture</li>
              <li>Completed <strong>React Native Bare Workflow Training</strong> — built 2 mini projects and a capstone iOS/Android app</li>
              <li>Attended <strong>Manager Bootcamp</strong> focused on collaborative leadership and Agile team practices</li>
            </ul>
            <div class="exp-tags">
              <span class="skill-tag">Kotlin</span>
              <span class="skill-tag">Room DB</span>
              <span class="skill-tag">React Native</span>
              <span class="skill-tag">Firebase</span>
              <span class="skill-tag">GitLab</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Education -->
      <div class="timeline-item">
        <div class="timeline-dot edu"></div>
        <div class="timeline-content">
          <div class="exp-card">
            <div class="exp-top">
              <div class="exp-company-logo ust">UST</div>
              <div class="exp-info">
                <h3 class="exp-title">Bachelor of Science in Information Technology</h3>
                <p class="exp-company">University of Santo Tomas</p>
              </div>
              <span class="exp-badge edu-badge">Education</span>
            </div>
            <p class="exp-date">2021 – 2025 · Manila, Philippines</p>
            <ul class="exp-bullets">
              <li>Completed degree in Information Technology with specialized on web and mobile applications development</li>
              <li>Built RideSync — a cross-platform for group road trips as a Capstone Project</li>
              <li>Developed multiple mobile and web applications across Android, Flutter, and React Native</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.experience {
  padding: 100px 0;
  border-top: 1px solid var(--border);
}

.exp-header {
  margin-bottom: 56px;
}

/* Timeline */
.timeline {
  position: relative;
  max-width: 780px;
  margin: 0 auto;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 12px;
  bottom: 0;
  width: 1px;
  background: var(--border);
}

.timeline-item {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 24px;
  margin-bottom: 32px;
}

.timeline-dot {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid var(--border);
  background: var(--bg);
  margin-top: 18px;
  position: relative;
  z-index: 1;
  flex-shrink: 0;
}

.timeline-dot.active {
  border-color: var(--accent);
  background: var(--accent);
  box-shadow: 0 0 0 4px rgba(232,103,58,0.15);
}

.timeline-dot.edu { border-color: var(--blue); background: rgba(96,165,250,0.2); }

.exp-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  transition: border-color var(--transition);
}

.exp-card:hover { border-color: var(--border2); }

.timeline-item.current .exp-card {
  border-color: rgba(232,103,58,0.3);
}

.exp-top {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 8px;
}

.exp-company-logo {
  width: 40px; height: 40px;
  border-radius: 10px;
  background: var(--accent-dim);
  border: 1px solid var(--accent);
  color: var(--accent);
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exp-company-logo.intern { opacity: 0.7; }

.exp-company-logo.ust {
  background: rgba(96,165,250,0.08);
  border-color: rgba(96,165,250,0.3);
  color: var(--blue);
  font-size: 11px;
}

.exp-info { flex: 1; }

.exp-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
}

.exp-company {
  font-size: 13px;
  color: var(--text3);
  margin-top: 2px;
}

.exp-badge {
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 10px;
  font-weight: 700;
  font-family: var(--font-display);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
  flex-shrink: 0;
}

.current-badge {
  background: rgba(74,222,128,0.1);
  border: 1px solid rgba(74,222,128,0.3);
  color: var(--green);
}

.intern-badge {
  background: var(--accent-dim);
  border: 1px solid rgba(232,103,58,0.3);
  color: var(--accent2);
}

.edu-badge {
  background: rgba(96,165,250,0.08);
  border: 1px solid rgba(96,165,250,0.25);
  color: var(--blue);
}

.exp-date {
  font-size: 12px;
  color: var(--text3);
  margin-bottom: 14px;
}

.exp-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 16px;
}

.exp-bullets li {
  font-size: 14px;
  color: var(--text2);
  padding-left: 14px;
  position: relative;
  line-height: 1.6;
}

.exp-bullets li::before {
  content: '';
  position: absolute;
  left: 0; top: 9px;
  width: 5px; height: 1px;
  background: var(--accent);
}

.exp-bullets strong { color: var(--text); font-weight: 500; }

.exp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.skill-tag {
  padding: 3px 10px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 100px;
  font-size: 11px;
  color: var(--text3);
}

@media (max-width: 600px) {
  .timeline::before { left: 12px; }
  .timeline-item { grid-template-columns: 28px 1fr; gap: 16px; }
  .exp-top { flex-wrap: wrap; }
  .exp-badge { order: 3; }
}
</style>

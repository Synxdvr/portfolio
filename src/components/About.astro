<section class="about" id="about">
  <div class="container about-inner">
    <div class="about-text">
      <p class="section-label">About me</p>
      <h2 class="section-title">Turning real problems<br/>into working software</h2>
      <div class="about-body">
        <p>
          Hi, I'm <em>Steve</em> — a <strong>Software Engineer</strong> from the Philippines with a knack for
          building things that actually work for people. I graduated with a
          <strong>Bachelor's in Information Technology from the University of Santo Tomas</strong>
          in 2025, but my love for technology started way before that — the kind that
          starts with gadgets and ends up in a code editor.
        </p>
        <p>
          I specialize in <strong>mobile development</strong>, particularly Android, 
          where I've had the opportunity to build and deliver production-level features 
          for a major airline application used in real-world operations. Seeing my work 
          run in a live environment strengthened my focus on writing reliable, scalable 
          code and creating user experiences that make sense.
        </p>
        <p>
          Right now, I’m also working toward becoming a <strong>Cloud/DevOps-focused engineer.</strong> 
          I’m actively learning how to build, deploy, and scale applications in real production environments, 
          not just develop them. My goal is to grow into an engineer who can handle the full lifecycle of a 
          product — from development to deployment and long-term reliability.
        </p>
      </div>
      <div class="about-chips">
        <span class="chip">🎓 BS Information Technology</span>
        <span class="chip">🏢 IBM</span>
        <span class="chip">📍 Philippines</span>
        <span class="chip">🚀 Open to opportunities</span>
      </div>
    </div>
    <div class="about-aside">
      <div class="about-card">
        <div class="about-avatar">
          <div class="avatar-placeholder">
            <span>SD</span>
          </div>
          <div class="avatar-ring"></div>
        </div>
        <div class="about-meta">
          <p class="meta-name">Steve C. De Vera</p>
          <p class="meta-role">Software Engineer</p>
        </div>
        <div class="about-links">
          <a href="https://github.com/synxdvr" target="_blank" class="about-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/scdvrxd" target="_blank" class="about-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="/cv.pdf" target="_blank" rel="noopener noreferrer" class="about-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Resume
          </a>
        </div>
      </div>
      <div class="fun-facts">
        <div class="fun-fact">
          <span class="ff-icon">⚡</span>
          <div>
            <p class="ff-title">Internship → Full-time</p>
            <p class="ff-sub">Absorbed by Stratpoint after internship ended</p>
          </div>
        </div>
        <div class="fun-fact">
          <span class="ff-icon">👨🏻‍💻</span>
          <div>
            <p class="ff-title">Code to Productions</p>
            <p class="ff-sub">Delivered features that go to productions</p>
          </div>
        </div>
        <div class="fun-fact">
          <span class="ff-icon">📱</span>
          <div>
            <p class="ff-title">3 platforms</p>
            <p class="ff-sub">Native Mobile, Cross-Platform, Web Applications</p>
          </div>
        </div>
        <div class="fun-fact">
          <span class="ff-icon">🤝</span>
          <div>
            <p class="ff-title">Real client delivered</p>
            <p class="ff-sub">PrioriTrack — shipped to production</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.about {
  padding: 100px 0;
  border-top: 1px solid var(--border);
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 80px;
  align-items: start;
}

.about-text .section-title { margin-bottom: 28px; }

.about-body {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 28px;
}

.about-body p {
  font-size: 16px;
  color: var(--text2);
  line-height: 1.8;
}

.about-body strong { color: var(--text); font-weight: 500; }
.about-body em { color: var(--accent2); font-style: normal; }

.about-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chip {
  padding: 6px 14px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 100px;
  font-size: 13px;
  color: var(--text2);
}

/* Card */
.about-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  text-align: center;
  margin-bottom: 16px;
}

.about-avatar {
  position: relative;
  width: 96px; height: 96px;
  margin: 0 auto 16px;
}

.avatar-placeholder {
  width: 96px; height: 96px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-dim), var(--bg3));
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  color: var(--accent);
}

.avatar-ring {
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1.5px dashed var(--border2);
  animation: spin 20s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.meta-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  color: var(--text);
}
.meta-role {
  font-size: 13px;
  color: var(--text3);
  margin-top: 2px;
  margin-bottom: 20px;
}

.about-links {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}

.about-link {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 100px;
  font-size: 13px;
  color: var(--text2);
  transition: color var(--transition), border-color var(--transition);
}
.about-link:hover { color: var(--text); border-color: var(--text2); }

/* Fun facts */
.fun-facts {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.fun-fact {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color var(--transition);
}
.fun-fact:hover { border-color: var(--border2); }

.ff-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

.ff-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 2px;
}
.ff-sub {
  font-size: 12px;
  color: var(--text3);
  line-height: 1.4;
}

@media (max-width: 960px) {
  .about-inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .about-aside {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }
  .about-card { margin-bottom: 0; }
}

@media (max-width: 600px) {
  .about-aside { grid-template-columns: 1fr; }
}
</style>

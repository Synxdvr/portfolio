---
<section class="contact" id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-text">
        <p class="section-label">Get in touch</p>
        <h2 class="section-title">Let's build something<br/><span>together</span></h2>
        <p class="contact-desc">
          Open to full-time Software Engineer roles, freelance projects, and
          collaborations. If you have a problem worth solving, I'd love to hear about it.
        </p>
        <div class="contact-items">
          <a href="mailto:stevedevera30@email.com" class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="ci-label">Email</p>
              <p class="ci-value">stevedevera30@email.com</p>
            </div>
          </a>
          <a href="https://github.com/synxdvr" target="_blank" class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            </div>
            <div>
              <p class="ci-label">GitHub</p>
              <p class="ci-value">github.com/synxdvr</p>
            </div>
          </a>
          <a href="https://linkedin.com/in/scdvrxd" target="_blank" class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div>
              <p class="ci-label">LinkedIn</p>
              <p class="ci-value">linkedin.com/in/scdvrxd</p>
            </div>
          </a>
        </div>
      </div>

      <form class="contact-form" id="contact-form">
        <div class="form-group">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" placeholder="Jane Recruiter" required />
        </div>
        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="jane@company.com" required />
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <select id="subject" name="subject">
            <option value="">Select a topic...</option>
            <option>Job opportunity</option>
            <option>Freelance project</option>
            <option>Collaboration</option>
            <option>Just saying hi</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell me about the role, project, or what you have in mind..." required></textarea>
        </div>
        <button type="submit" class="btn-primary form-submit">
          Send message
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
        <p class="form-note">I typically reply within 24 hours.</p>
      </form>
    </div>
  </div>

  <footer class="footer">
    <div class="container footer-inner">
      <p class="footer-copy">© 2025 Steve C. De Vera · Built with Astro</p>
      <div class="footer-links">
        <a href="https://github.com/synxdvr" target="_blank">GitHub</a>
        <a href="https://linkedin.com/in/scdvrxd" target="_blank">LinkedIn</a>
        <a href="mailto:stevedevera30@email.com">Email</a>
      </div>
    </div>
  </footer>
</section>

<style>
.contact {
  padding: 100px 0 0;
  border-top: 1px solid var(--border);
}

.contact-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
  padding-bottom: 100px;
}

.contact-text .section-title {
  margin-bottom: 20px;
}

.contact-text .section-title span { color: var(--accent); }

.contact-desc {
  font-size: 16px;
  color: var(--text2);
  line-height: 1.75;
  margin-bottom: 36px;
  max-width: 400px;
}

.contact-items {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color var(--transition);
}
.contact-item:hover { border-color: var(--border2); }

.contact-item-icon {
  width: 40px; height: 40px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  flex-shrink: 0;
}

.ci-label {
  font-size: 11px;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 2px;
}

.ci-value {
  font-size: 14px;
  color: var(--text2);
  font-weight: 500;
}

/* Form */
.contact-form {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text2);
}

.form-group input,
.form-group select,
.form-group textarea {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 11px 14px;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  transition: border-color var(--transition);
  outline: none;
  resize: vertical;
}

.form-group input::placeholder,
.form-group textarea::placeholder {
  color: var(--text3);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--accent);
}

.form-group select {
  cursor: pointer;
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%235a5753' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 14px center;
}

.form-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  border: none;
  cursor: pointer;
  font-family: var(--font-body);
}

.form-note {
  text-align: center;
  font-size: 12px;
  color: var(--text3);
  margin-top: -8px;
}

/* Footer */
.footer {
  border-top: 1px solid var(--border);
  padding: 24px 0;
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.footer-copy {
  font-size: 13px;
  color: var(--text3);
}

.footer-links {
  display: flex;
  gap: 20px;
}

.footer-links a {
  font-size: 13px;
  color: var(--text3);
  transition: color var(--transition);
}
.footer-links a:hover { color: var(--text2); }

@media (max-width: 900px) {
  .contact-inner { grid-template-columns: 1fr; gap: 48px; }
  .footer-inner { flex-direction: column; text-align: center; }
}
</style>

<script>
document.getElementById('contact-form')?.addEventListener('submit', (e) => {
  e.preventDefault();
  const btn = e.currentTarget as HTMLFormElement;
  const submit = btn.querySelector('.form-submit') as HTMLButtonElement;
  submit.textContent = '✓ Message sent!';
  submit.style.background = 'var(--green)';
  submit.style.opacity = '0.8';
  setTimeout(() => {
    submit.textContent = 'Send message';
    submit.style.background = '';
    submit.style.opacity = '';
    (e.currentTarget as HTMLFormElement).reset();
  }, 3000);
});
</script>
